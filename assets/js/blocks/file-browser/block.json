{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ninja-drive/file-browser",
    "version": "1.0.0",
    "title": "File Browser",
    "category": "ninja-drive",
    "icon": "format-gallery",
    "description": "Display files from Google Drive as a file browser",
    "keywords": ["file browser", "google drive", "files"],
    "textdomain": "ninja-drive",
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "spacing": {
            "margin": true,
            "padding": true
        }
    },
    "attributes": {
        "id": {
            "type": "number"
        },
        "type": {
            "type": "string",
            "default": "file_browser"
        }
    },
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": [
        "file:../../../../assets/css/admin.css",
        "file:../../../../assets/css/common.css"
    ]
}
