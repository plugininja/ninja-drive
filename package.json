{
  "name": "ninja-drive",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A simple modern wordpress google cloud storage plugin",
  "files": [
    "app",
    "assets",
    "core",
    "freemius",
    "includes",
    "languages",
    "models",
    "templates",
    "vendors",
    "index.php",
    "ninja-drive.php",
    "readme.txt",
    "uninstall.php"
  ],
  "scripts": {
    "build:tokens": "node scripts/build-tokens.js",
    "dev-admin": "webpack serve --config webpack.dev.config.js",
    "build-admin": "webpack --config webpack.prod.config.js",
    "watch-assets": "npm run build:tokens && wp-scripts start --config webpack.dev.config.js",
    "watch-sass": "node scripts/watch-css.js",
    "buildSass": "npm run build:tokens && sass source/assets/sass:assets/css --style=compressed --no-source-map",
    "buildPostcss": "postcss assets/css/**/*.css --replace --no-map",
    "start": "concurrently \"npm:watch-*\"",
    "dev-hot": "concurrently \"npm:watch-sass\" \"npm:dev-admin\" ",
    "clean-maps": "find . \\( -name \"*.map\" -o -name \".DS_Store\" \\) -type f -delete",
    "plugin:zip": "wp-scripts plugin-zip",
    "lint": "eslint source/ --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint source/ --ext .js,.jsx,.ts,.tsx --fix",
    "strip-premium": "node scripts/strip-premium__premium_only.js",
    "zip:free": "node scripts/zip-free__premium_only.js",
    "build:free": "npm run buildSass && npm run buildPostcss && npm run build-admin && npm run strip-premium && npm run zip:free",
    "test:php": "wp-env run tests-cli phpunit",
    "test:php:start": "wp-env start && wp-env run tests-cli phpunit",
    "build": "npm run buildSass && npm run buildPostcss && concurrently \"npm:build-*\" && npm run clean-maps",
    "make-pot": "wp i18n make-pot . languages/ninja-drive.pot --domain=ninja-drive --slug=ninja-drive --package-name=\"Ninja Drive\" --headers='{\"Report-Msgid-Bugs-To\":\"https://wordpress.org/support/plugin/ninja-drive\"}'",
    "build:zip": "npm run build && npm run plugin:zip && npm run build:free"
  },
  "keywords": [
    "wordpress",
    "google-drive",
    "google-cloud-storage",
    "google-drive-api",
    "google-drive-plugin"
  ],
  "author": "Plugininja",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.15.17",
    "@types/plupload": "^2.0.14",
    "@types/wordpress__block-editor": "^11.5.17",
    "@wordpress/block-editor": "^15.5.0",
    "@wordpress/components": "^30.5.0",
    "@wordpress/element": "^6.23.0",
    "@wordpress/env": "^10.39.0",
    "@wordpress/i18n": "^5.6.0",
    "@wordpress/scripts": "^31.4.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^13.0.0",
    "cssnano": "^7.0.7",
    "glob": "^11.0.2",
    "plupload": "^2.3.9",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-preset-env": "^10.4.0",
    "swiper": "^11.2.10",
    "typescript": "^5.6.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.3.0",
    "clsx": "^2.1.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^7.6.1",
    "sass": "^1.77.8"
  }
}